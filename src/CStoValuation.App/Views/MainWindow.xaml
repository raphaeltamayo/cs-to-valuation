<Window x:Class="CStoValuation.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:CStoValuation.App.Views"
        xmlns:vm="clr-namespace:CStoValuation.App.ViewModels"
        mc:Ignorable="d"
        x:ClassModifier="internal"
        Title="CS2 Inventory Valuator"
        Height="760" Width="1180"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Connect bar ===== -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding SteamInput, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsNotBusy}"
                     FontSize="14"
                     ToolTip="SteamID64, profile URL (/profiles/…), or custom URL (/id/…)" />

            <Button Grid.Column="1" Margin="10,0,0,0"
                    Style="{StaticResource AccentButton}"
                    Content="Connect"
                    Command="{Binding ConnectCommand}" />

            <Button Grid.Column="2" Margin="10,0,0,0"
                    Content="Sign in through Steam"
                    IsEnabled="False"
                    ToolTip="OpenID sign-in (added in the next step)" />

            <Button Grid.Column="3" Margin="10,0,0,0"
                    Content="Refresh"
                    Command="{Binding RefreshCommand}" />
        </Grid>

        <!-- ===== Placeholder watermark over the empty text box ===== -->
        <TextBlock Grid.Row="0"
                   Text="Paste a SteamID64 or profile URL to begin…"
                   Foreground="{StaticResource MutedTextBrush}"
                   Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SteamInput}" Value="">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- ===== Summary panel ===== -->
        <Border Grid.Row="1" Margin="0,16,0,0"
                Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="22,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Net value is the headline: what you'd actually realize after fees. -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="NET VALUE (AFTER FEES)" FontSize="11"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock Text="{Binding Summary.TotalNetText}" FontSize="34" FontWeight="Bold"
                               Foreground="{StaticResource PositiveBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="0,0,0,6">
                    <TextBlock Text="GROSS (MARKET)" FontSize="11"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock Text="{Binding Summary.TotalGrossText}" FontSize="20" FontWeight="SemiBold" />
                </StackPanel>

                <StackPanel Grid.Column="4" VerticalAlignment="Bottom" Margin="0,0,0,6"
                            HorizontalAlignment="Right">
                    <TextBlock Text="{Binding Summary.Currency}" FontSize="11"
                               Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Right" />
                    <TextBlock Text="{Binding Summary.CountsText}" FontSize="13"
                               Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Private-inventory / error banner ===== -->
        <Border Grid.Row="2" Margin="0,12,0,0"
                Background="{StaticResource SurfaceMutedBrush}" CornerRadius="8" Padding="16,12"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                       Foreground="{StaticResource DangerBrush}" />
        </Border>

        <!-- ===== Status + progress ===== -->
        <Grid Grid.Row="3" Margin="2,12,2,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedTextBrush}"
                       VerticalAlignment="Center" />
            <ProgressBar Height="3" IsIndeterminate="True" BorderThickness="0"
                         Background="Transparent" Foreground="{StaticResource AccentBrush}"
                         VerticalAlignment="Bottom"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
        </Grid>

        <!-- ===== Inventory grid (inherits this window's DataContext) ===== -->
        <views:InventoryView Grid.Row="4" Margin="0,12,0,0" />
    </Grid>
</Window>
