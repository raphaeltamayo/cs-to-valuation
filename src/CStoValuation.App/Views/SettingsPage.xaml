<UserControl x:Class="CStoValuation.App.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CStoValuation.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsPageViewModel}">

    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="24"
            MaxWidth="480" HorizontalAlignment="Left" VerticalAlignment="Top">
        <StackPanel>
            <TextBlock Text="PRICING" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,10" />

            <TextBlock Text="Primary source (used for the inventory total)" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding PrimarySourceOptions}"
                      SelectedItem="{Binding SelectedPrimarySource}"
                      HorizontalAlignment="Left" Width="200" Margin="0,0,0,16" />

            <TextBlock Text="Enabled sources (shown on the item detail panel)"
                       Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,6" />
            <CheckBox Content="Skinport" IsChecked="{Binding IsSkinportEnabled}" Margin="0,0,0,6" />
            <CheckBox Content="PriceEmpire" IsChecked="{Binding IsPriceEmpireEnabled}" Margin="0,0,0,6" />
            <CheckBox Content="CSFloat" IsChecked="{Binding IsCsFloatEnabled}" Margin="0,0,0,16" />

            <TextBlock Text="PriceEmpire API key" Margin="0,0,0,4" />
            <TextBox Text="{Binding PriceEmpireApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
            <TextBlock Text="Stored locally; leave blank to disable PriceEmpire pricing."
                       Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,0,0,16" />

            <TextBlock Text="Currency" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding CurrencyOptions}"
                      SelectedItem="{Binding Currency}"
                      HorizontalAlignment="Left" Width="120" Margin="0,0,0,20" />

            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource AccentButton}" Content="Save" Command="{Binding SaveCommand}" />
                <TextBlock Text="{Binding StatusMessage}" Margin="12,0,0,0" VerticalAlignment="Center"
                           Foreground="{StaticResource PositiveBrush}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
