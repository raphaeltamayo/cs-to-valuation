<UserControl x:Class="CStoValuation.App.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:behaviors="clr-namespace:CStoValuation.App.Behaviors"
             xmlns:vm="clr-namespace:CStoValuation.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">

    <UserControl.Resources>
        <!-- Column headers -->
        <Style x:Key="GridHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <!-- Cells: no editing chrome, comfortable padding -->
        <Style x:Key="GridCellStyle" TargetType="{x:Type DataGridCell}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RightAlignedText" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Filter box -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Filter by item name" />
                <TextBlock Grid.Column="1" Margin="12,0,4,0" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="{Binding ItemsView.Count, StringFormat='{}{0} shown'}" />
            </Grid>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding ItemsView}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      SelectionMode="Single"
                      Background="Transparent"
                      RowBackground="Transparent"
                      Foreground="{StaticResource TextBrush}"
                      BorderThickness="0"
                      EnableRowVirtualization="True"
                      ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                      CellStyle="{StaticResource GridCellStyle}"
                      RowHeight="44">
                <DataGrid.Columns>

                    <!-- Icon -->
                    <DataGridTemplateColumn Header="" Width="56" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Image behaviors:ImageLoader.SourceUrl="{Binding ImageUrl}"
                                       Width="44" Height="33" Stretch="Uniform" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Name -->
                    <DataGridTextColumn Header="Item" Binding="{Binding Name}" Width="*" />

                    <!-- Rarity chip -->
                    <DataGridTemplateColumn Header="Rarity" Width="130" SortMemberPath="Rarity">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="8,3" HorizontalAlignment="Left"
                                        Background="{Binding Rarity, Converter={StaticResource RarityToBrush}}"
                                        Visibility="{Binding HasRarity, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="{Binding RarityLabel}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#FF14161A" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Exterior -->
                    <DataGridTextColumn Header="Exterior" Binding="{Binding ExteriorLabel}" Width="120"
                                        ElementStyle="{StaticResource {x:Type TextBlock}}" />

                    <!-- Quantity -->
                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="60"
                                        ElementStyle="{StaticResource RightAlignedText}" />

                    <!-- Unit prices -->
                    <DataGridTextColumn Header="Unit (gross)" Binding="{Binding UnitGrossText}"
                                        SortMemberPath="UnitGross" Width="110"
                                        ElementStyle="{StaticResource RightAlignedText}" />
                    <DataGridTextColumn Header="Unit (net)" Binding="{Binding UnitNetText}"
                                        SortMemberPath="UnitNet" Width="110"
                                        ElementStyle="{StaticResource RightAlignedText}" />

                    <!-- Line totals -->
                    <DataGridTextColumn Header="Line (gross)" Binding="{Binding LineGrossText}"
                                        SortMemberPath="LineGross" Width="120"
                                        ElementStyle="{StaticResource RightAlignedText}" />
                    <DataGridTextColumn Header="Line (net)" Binding="{Binding LineNetText}"
                                        SortMemberPath="LineNet" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource RightAlignedText}">
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
